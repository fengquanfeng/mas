# ============================================
# 通用忽略规则
# ============================================

# 依赖目录
node_modules/
.pnp
.pnp.js

# 构建输出
dist/
build/
out/
*.tsbuildinfo

# 日志文件
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# 环境变量文件（保留示例文件）
.env
.env.local
.env.*.local

# 编辑器/IDE
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-workspace
*.sublime-project

# 操作系统文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# 测试覆盖率
coverage/
.nyc_output/

# 临时文件
tmp/
temp/
*.tmp
*.temp
.cache/

# ============================================
# 前端特有规则 (frontend/)
# ============================================

frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.env
frontend/.env.local
frontend/.env.*.local
frontend/*.local

# ============================================
# 后端特有规则 (backend/)
# ============================================

backend/node_modules/
backend/dist/
backend/.env
backend/.env.local
backend/.env.*.local
backend/ormconfig.json

# ============================================
# 其他工具
# ============================================

# ESLint
.eslintcache

# Prettier
.prettiercache

# TypeScript
*.tsbuildinfo

# 可选：锁定文件（根据团队规范决定是否忽略）
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
